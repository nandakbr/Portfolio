<!DOCTYPE html>
<html class="scroll-smooth dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>
        <%= title %>
    </title>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link
        href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" media="print" onload="this.media='all'" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography,container-queries"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#000000",
                        "primary-secondary": "#666666",
                        "background-light": "#F9F9F9",
                        "background-dark": "#050505",
                        "background-elevated": "#111111",
                        "cta-default": "#000000",
                        "cta-hover": "#333333",
                        "btn-default": "#000000",
                        "btn-hover": "#333333",
                        "border-color": "#E5E5E5",
                    },
                    fontFamily: {
                        display: ["Outfit", "sans-serif"],
                        body: ["Outfit", "sans-serif"],
                    },
                    borderRadius: {
                        DEFAULT: "0.5rem",
                        '4xl': '2rem',
                    },
                },
            },
        };
    </script>
    <style type="text/tailwindcss">
        :root {
            --ease-apple: cubic-bezier(0.22, 1, 0.36, 1);
            --ease-apple-soft: cubic-bezier(0.16, 1, 0.3, 1);
            --ease-apple-snap: cubic-bezier(0.34, 1.56, 0.64, 1);
            --duration-reveal: 1100ms;
        }

        .reveal-init {
            @apply opacity-0 translate-y-16 scale-[0.97];
            filter: blur(10px);
            transition:
                opacity var(--duration-reveal) var(--ease-apple),
                transform var(--duration-reveal) var(--ease-apple),
                filter calc(var(--duration-reveal) * 0.9) var(--ease-apple-soft);
            will-change: transform, opacity, filter;
        }

        .reveal-active {
            @apply opacity-100 translate-y-0 scale-100;
            filter: blur(0);
        }

        section {
            @apply relative z-10;
        }

        body,
        h1,
        h2,
        h3,
        .nav-link {
            font-family: 'Outfit', sans-serif;
        }

        .parallax-layer {
            --px: 0px;
            --py: 0px;
            translate: var(--px) var(--py);
            will-change: transform, translate;
        }

        .hero-img-container {
            border-radius: 4rem;
            overflow: hidden;
            mask-image: linear-gradient(to top, transparent 0%, black 40%);
            -webkit-mask-image: linear-gradient(to top, transparent 0%, black 40%);
            box-shadow: 0 34px 80px rgba(0, 0, 0, 0.35);
        }

        .footer-cta-bg {
            background: linear-gradient(135deg, #050505 0%, #111111 50%, #050505 100%);
            position: relative;
            overflow: hidden;
        }

        .footer-cta-bg::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -20%;
            width: 150%;
            height: 150%;
            background: radial-gradient(circle at center, rgba(255, 255, 255, 0.08) 0%, transparent 70%);
            filter: blur(60px);
            pointer-events: none;
        }

        .footer-cta-bg::after {
            content: '';
            position: absolute;
            top: 20%;
            right: -10%;
            width: 80%;
            height: 60%;
            background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.05) 0%, transparent 80%);
            transform: rotate(-15deg);
            filter: blur(40px);
            pointer-events: none;
        }

        .bento-card {
            @apply relative overflow-hidden border-none;
            background-color: #F5F5F7;
            transition:
                transform 900ms var(--ease-apple),
                box-shadow 900ms var(--ease-apple),
                background-color 500ms var(--ease-apple-soft);
            box-shadow: 0 1px 0 rgba(255, 255, 255, 0.1) inset;
        }

        .dark .bento-card {
            background-color: #1C1C1E;
        }

        .bento-image-container {
            @apply relative w-full overflow-hidden flex items-center justify-center p-6 lg:p-8;
            transition: transform 1000ms var(--ease-apple);
        }

        .bento-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 30px 70px rgba(0, 0, 0, 0.18);
        }

        .dark .bento-card:hover {
            box-shadow: 0 30px 70px rgba(0, 0, 0, 0.42);
        }

        .eraser-cutout::before,
        .eraser-cutout::after {
            content: "";
            position: absolute;
            background-color: transparent;
            pointer-events: none;
            width: 3rem;
            height: 3rem;
        }

        .eraser-cutout::before {
            top: 0;
            left: -3rem;
            border-top-right-radius: 3rem;
            box-shadow: 1.5rem -1.5rem 0 1.5rem #F9F9F9;
        }

        .eraser-cutout::after {
            bottom: -3rem;
            right: 0;
            border-top-right-radius: 3rem;
            box-shadow: 1.5rem -1.5rem 0 1.5rem #F9F9F9;
        }

        .dark .eraser-cutout::before,
        .dark .eraser-cutout::after {
            box-shadow: 1.5rem -1.5rem 0 1.5rem #050505;
        }

        .bento-card:hover .bento-image-container {
            @apply scale-[1.04];
        }

        .bento-card-container {
            perspective: 2200px;
        }

        .bento-tilt {
            transition: transform 900ms var(--ease-apple-soft);
            transform-style: preserve-3d;
        }

        .bento-card-container:hover .bento-tilt {
            transform: rotateX(1.5deg) rotateY(-1.5deg);
        }

        .magnetic-btn:hover span {
            @apply translate-x-2;
        }

        .bg-text {
            @apply absolute -left-20 text-[20vw] font-bold opacity-[0.02] select-none pointer-events-none tracking-tighter whitespace-nowrap leading-none font-display z-0;
        }

        @keyframes scrollPulse {
            0%,
            100% {
                transform: translateY(0) scale(1);
                opacity: 0.95;
            }

            50% {
                transform: translateY(8px) scale(0.96);
                opacity: 0.6;
            }
        }

        .scroll-pulse {
            animation: scrollPulse 2.8s var(--ease-apple-soft) infinite;
        }

        .tilt-left {
            transform: rotate(0deg);
        }

        .word-carousel-container {
            display: inline-block;
            height: 1.2em;
            overflow: hidden;
            vertical-align: bottom;
            position: relative;
        }

        #word-carousel {
            display: flex;
            flex-direction: column;
            transition: transform 0.65s var(--ease-apple-soft);
            will-change: transform;
        }

        .carousel-word {
            height: 1.2em;
            line-height: 1.2em;
            display: block;
        }

        #scramble-word {
            display: inline-block;
            min-width: 4.6ch;
            text-align: center;
        }

        .hero-background {
            position: absolute;
            inset: -2%;
            z-index: -1;
            overflow: hidden;
            background: radial-gradient(circle at 50% 50%, #111 0%, #000 100%);
            -webkit-mask-image: linear-gradient(to bottom, black 78%, transparent 100%);
            mask-image: linear-gradient(to bottom, black 78%, transparent 100%);
        }

        .hero-background::before {
            content: "";
            position: absolute;
            inset: -12%;
            background: radial-gradient(circle at 30% 25%, rgba(255, 255, 255, 0.18), transparent 55%);
            filter: blur(60px);
            animation: heroGlow 14s var(--ease-apple-soft) infinite alternate;
            pointer-events: none;
            z-index: 1;
        }

        .bg-slide {
            position: absolute;
            inset: -12%;
            background-size: cover;
            background-position: center;
            opacity: 0;
            animation: slide-fade 36s infinite var(--ease-apple-soft);
            will-change: opacity, transform, filter;
            filter: brightness(0.72) contrast(1.08);
            transform: scale(1.04) translate3d(0, 0, 0);
        }

        .bg-slide:nth-child(1) {
            background-image: url('/assets/Bonus.png');
            animation-delay: 0s;
        }

        .bg-slide:nth-child(2) {
            background-image: url('/assets/Monochrome%20-%209.png');
            animation-delay: 9s;
        }

        .bg-slide:nth-child(3) {
            background-image: url('/assets/6.png');
            animation-delay: 18s;
        }

        .bg-slide:nth-child(4) {
            background-image: url('/assets/7.png');
            animation-delay: 27s;
        }

        @keyframes heroGlow {
            0% {
                transform: translate3d(-3%, -2%, 0) scale(1);
                opacity: 0.4;
            }

            100% {
                transform: translate3d(3%, 2%, 0) scale(1.08);
                opacity: 0.8;
            }
        }

        @keyframes slide-fade {
            0% {
                opacity: 0;
                transform: scale(1.04) translate3d(-1%, -1%, 0);
                filter: blur(20px) brightness(0.45);
            }

            10% {
                opacity: 1;
                filter: blur(0px) brightness(0.82);
            }

            38% {
                opacity: 1;
                transform: scale(1.08) translate3d(1.5%, 1%, 0);
                filter: blur(0px) brightness(0.82);
            }

            52% {
                opacity: 0;
                transform: scale(1.12) translate3d(3%, 2%, 0);
                filter: blur(20px) brightness(0.45);
            }

            100% {
                opacity: 0;
                transform: scale(1.12) translate3d(3%, 2%, 0);
            }
        }

        .hero-background::after {
            content: "";
            position: absolute;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
            opacity: 0.05;
            mix-blend-mode: overlay;
            pointer-events: none;
            z-index: 2;
        }

        @keyframes scrollBtnEnter {
            from {
                opacity: 0;
                transform: translateY(2rem) scale(0.9);
                filter: blur(8px);
            }

            to {
                opacity: 1;
                transform: translateY(0) scale(1);
                filter: blur(0);
            }
        }

        .scroll-btn-enter {
            opacity: 0;
            animation: scrollBtnEnter 1.2s var(--ease-apple) 1.6s forwards;
        }

        .chat-bubble {
            @apply flex items-center justify-center rounded-[20px] text-2xl lg:text-3xl shadow-xl transition-all duration-300 relative;
            width: 4rem;
            height: 4rem;
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.34), rgba(255, 255, 255, 0.12));
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border: 1px solid rgba(255, 255, 255, 0.35);
            box-shadow: 0 20px 45px rgba(0, 0, 0, 0.15);
            animation: floatBubble 10s var(--ease-apple-soft) infinite;
            will-change: transform;
        }

        .dark .chat-bubble {
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.04));
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 18px 44px rgba(0, 0, 0, 0.52);
        }

        @keyframes floatBubble {
            0%,
            100% {
                transform: translate3d(0, 0, 0) rotate(0deg) scale(1);
            }

            50% {
                transform: translate3d(0, -14px, 0) rotate(2.4deg) scale(1.06);
            }
        }

        .bubble-1 {
            top: 20%;
            left: 12%;
        }

        .bubble-2 {
            top: 28%;
            right: 15%;
        }

        .bubble-3 {
            bottom: 25%;
            left: 18%;
        }

        .bubble-4 {
            bottom: 35%;
            right: 12%;
        }

        .bubble-5 {
            top: 45%;
            left: 28%;
        }

        .bubble-1 .chat-bubble {
            animation-delay: 0s;
        }

        .bubble-2 .chat-bubble {
            animation-delay: 1.2s;
        }

        .bubble-3 .chat-bubble {
            animation-delay: 2.5s;
        }

        .bubble-4 .chat-bubble {
            animation-delay: 3.8s;
        }

        .bubble-5 .chat-bubble {
            animation-delay: 1.7s;
        }

        @keyframes slideSelected {
            0%,
            100% {
                transform: translateX(-3%);
            }

            50% {
                transform: translateX(3%);
            }
        }

        @keyframes slideWork {
            0%,
            100% {
                transform: translateX(3%);
            }

            50% {
                transform: translateX(-3%);
            }
        }

        .animate-selected {
            animation: slideSelected 28s var(--ease-apple-soft) infinite;
            will-change: transform;
        }

        .animate-work {
            animation: slideWork 28s var(--ease-apple-soft) infinite;
            will-change: transform;
        }

        /* Skill card scatter hover */
        .skill-card {
            position: relative;
        }

        .skill-icon-base {
            position: relative;
            z-index: 10;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 3.25rem;
            height: 3.25rem;
            border-radius: 1.15rem;
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0.4));
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid rgba(0, 0, 0, 0.06);
            box-shadow: 0 14px 30px rgba(0, 0, 0, 0.1);
            color: #0B130F;
            transition:
                opacity 360ms var(--ease-apple),
                transform 420ms var(--ease-apple),
                filter 360ms var(--ease-apple);
            will-change: opacity, transform, filter;
        }

        .dark .skill-icon-base {
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.04));
            border: 1px solid rgba(255, 255, 255, 0.18);
            box-shadow: 0 16px 34px rgba(0, 0, 0, 0.5);
            color: #EEF3EE;
        }

        .skill-icon-base .material-symbols-outlined {
            font-size: 1.6rem;
            font-variation-settings: 'FILL' 0, 'wght' 500, 'GRAD' 0, 'opsz' 24;
        }

        .skill-card:hover .skill-icon-base {
            opacity: 0;
            transform: scale(0.4);
            filter: blur(8px);
        }

        .skill-scatter {
            position: absolute;
            inset: 0;
            pointer-events: none;
            z-index: 2;
        }

        .skill-squircle {
            position: absolute;
            width: 3rem;
            height: 3rem;
            border-radius: 1.1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0.4));
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid rgba(0, 0, 0, 0.06);
            box-shadow: 0 14px 30px rgba(0, 0, 0, 0.1);
            color: #0B130F;
            opacity: 0;
            transform: scale(0.4) translateY(14px) rotate(0deg);
            transition:
                opacity 700ms var(--ease-apple-soft),
                transform 800ms var(--ease-apple-snap);
            will-change: transform, opacity;
        }

        .dark .skill-squircle {
            background: linear-gradient(180deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.04));
            border: 1px solid rgba(255, 255, 255, 0.18);
            box-shadow: 0 16px 34px rgba(0, 0, 0, 0.5);
            color: #EEF3EE;
        }

        .skill-squircle .material-symbols-outlined {
            font-size: 1.5rem;
            font-variation-settings: 'FILL' 0, 'wght' 500, 'GRAD' 0, 'opsz' 24;
        }

        .skill-card:hover .skill-squircle {
            opacity: 1;
            transform: scale(1) translateY(0) rotate(var(--rot, 0deg));
            animation: squircleFloat 4.6s var(--ease-apple-soft) infinite;
        }

        .skill-card:hover .skill-squircle:nth-child(1) {
            transition-delay: 80ms;
            animation-delay: 1.1s;
        }

        .skill-card:hover .skill-squircle:nth-child(2) {
            transition-delay: 170ms;
            animation-delay: 1.4s;
        }

        .skill-card:hover .skill-squircle:nth-child(3) {
            transition-delay: 260ms;
            animation-delay: 1.7s;
        }

        .skill-card:hover .skill-squircle:nth-child(4) {
            transition-delay: 340ms;
            animation-delay: 2s;
        }

        @keyframes squircleFloat {
            0%,
            100% {
                transform: scale(1) translateY(0) rotate(var(--rot, 0deg));
            }

            50% {
                transform: scale(1.05) translateY(-5px) rotate(calc(var(--rot, 0deg) + 3deg));
            }
        }

        /* Selected Works mobile snap carousel */
        .work-dots {
            display: none;
        }

        @media (max-width: 767px) {
            .work-grid {
                display: flex;
                flex-direction: row;
                gap: 1rem;
                overflow-x: auto;
                overflow-y: visible;
                scroll-snap-type: x mandatory;
                scroll-behavior: smooth;
                scroll-padding-left: 2rem;
                padding: 1rem 2rem 1.5rem;
                margin-inline: -2rem;
                scrollbar-width: none;
                -ms-overflow-style: none;
                -webkit-overflow-scrolling: touch;
            }

            .work-grid::-webkit-scrollbar {
                display: none;
            }

            .work-grid > .work-card {
                flex: 0 0 calc(100vw - 6rem);
                height: 480px !important;
                aspect-ratio: auto !important;
                scroll-snap-align: start;
                scroll-snap-stop: always;
                transform: scale(0.94);
                transition: transform 700ms var(--ease-apple-soft);
                will-change: transform;
            }

            .work-grid > .work-card.work-card-active {
                transform: scale(1);
            }

            .work-dots {
                display: flex;
                justify-content: center;
                gap: 0.5rem;
                margin-top: 2rem;
            }

            .work-dot {
                width: 0.4rem;
                height: 0.4rem;
                border-radius: 9999px;
                background: currentColor;
                opacity: 0.2;
                border: none;
                padding: 0;
                cursor: pointer;
                transition:
                    width 420ms var(--ease-apple-soft),
                    opacity 420ms var(--ease-apple-soft),
                    background-color 420ms var(--ease-apple-soft);
            }

            .work-dot.work-dot-active {
                width: 1.5rem;
                opacity: 0.9;
            }
        }

        @media (prefers-reduced-motion: reduce) {
            *,
            *::before,
            *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
                scroll-behavior: auto !important;
            }

            .parallax-layer {
                --px: 0px !important;
                --py: 0px !important;
            }

            .reveal-init {
                opacity: 1 !important;
                transform: none !important;
                filter: none !important;
            }
        }
    </style>
</head>

<body
    class="bg-background-light dark:bg-background-dark text-[#0B130F] dark:text-[#EEF3EE] transition-colors duration-300">
    <header class="fixed top-0 left-0 right-0 z-50 bg-transparent backdrop-blur-lg border-b border-white/5">
        <nav class="max-w-7xl mx-auto px-8 md:px-12 py-8 flex justify-between items-center">
            <a class="text-xl font-bold tracking-tight" href="/">Nanda Akbar</a>
            <div class="flex gap-10 items-center">
                <a class="nav-link text-lg hover:opacity-60 transition-opacity font-medium" href="/work">Work</a>
                <a class="nav-link text-lg hover:opacity-60 transition-opacity font-medium" href="/about">About</a>

            </div>
        </nav>
    </header>
    <main>
        <section class="relative w-full min-h-screen flex flex-col pt-32 mb-72 overflow-hidden">
            <!-- Background Slideshow -->
            <div class="hero-background parallax-layer" data-parallax-depth="4">
                <div class="bg-slide"></div>
                <div class="bg-slide"></div>
                <div class="bg-slide"></div>
                <div class="bg-slide"></div>
            </div>

            <!-- Floating Chat Bubbles -->
            <div class="absolute bubble-1 z-20 reveal-item parallax-layer" data-delay="500" data-parallax-depth="14">
                <div class="chat-bubble">✨</div>
            </div>
            <div class="absolute bubble-2 z-20 reveal-item parallax-layer" data-delay="700" data-parallax-depth="18">
                <div class="chat-bubble">🚀</div>
            </div>
            <div class="absolute bubble-3 z-20 reveal-item parallax-layer" data-delay="900" data-parallax-depth="12">
                <div class="chat-bubble">🔥</div>
            </div>
            <div class="absolute bubble-4 z-20 reveal-item parallax-layer" data-delay="1100" data-parallax-depth="16">
                <div class="chat-bubble">💡</div>
            </div>
            <div class="absolute bubble-5 z-20 reveal-item parallax-layer" data-delay="1300" data-parallax-depth="10">
                <div class="chat-bubble">🎨</div>
            </div>

            <div
                class="max-w-7xl mx-auto px-8 md:px-12 flex-grow flex flex-col justify-center items-center gap-12 lg:gap-16 text-center">
                <!-- Portrait -->
                <div class="w-48 md:w-56 lg:w-64 relative tilt-left shrink-0 reveal-item" data-delay="400">
                    <div class="hero-img-container parallax-layer aspect-[4/5] bg-[#3B82F6] relative group shadow-2xl" data-parallax-depth="8">
                        <img alt="Portrait of Nanda Akbar" class="w-full h-full object-cover object-center"
                            src="/assets/Main.webp" fetchpriority="high" decoding="async" />
                    </div>
                </div>

                <!-- Greeting -->
                <div class="text-xl md:text-3xl lg:text-4xl font-light tracking-tight reveal-item" data-delay="900">
                    hey <span class="word-carousel-container font-bold text-[#3B82F6] dark:text-[#EEF3EE]">
                        <span id="word-carousel">
                            <span class="carousel-word">peeps</span>
                            <span class="carousel-word">guys</span>
                            <span class="carousel-word">people</span>
                            <span class="carousel-word">folks</span>
                            <span class="carousel-word">ladies</span>
                            <span class="carousel-word">gents</span>
                        </span>
                    </span>! I'm Nanda
                </div>

                <!-- Headline -->
                <div class="max-w-4xl mx-auto reveal-item" data-delay="1400">
                    <h1 class="text-4xl md:text-5xl lg:text-6xl font-light leading-[1.1] tracking-tight">
                        I turn <span class="font-bold"><span id="scramble-word">messy</span> ideas</span> into clean
                        experiences that just <span class="font-bold relative inline-block">
                            <span id="click-word" class="inline-block transition-transform duration-150">click.</span>
                        </span>
                    </h1>
                </div>
            </div>

            <!-- Bottom: Scroll Prompt -->
