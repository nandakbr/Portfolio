    <script>

        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
        const isReducedMotion = () => prefersReducedMotion.matches;

        // Iframe Modal Logic
        const iframeModal = document.getElementById('iframe-modal');
        const modalIframe = document.getElementById('modal-iframe');
        const closeModalBtn = document.getElementById('iframe-modal-close');

        // Image Expand Logic
        const imageExpandModal = document.getElementById('image-expand-modal');
        const imageExpandImg = document.getElementById('image-expand-img');

        function openImageExpand(src) {
            imageExpandImg.src = src;
            imageExpandModal.classList.remove('hidden');
            void imageExpandModal.offsetWidth;
            imageExpandModal.classList.remove('opacity-0');
            imageExpandImg.classList.remove('scale-95');
            imageExpandImg.classList.add('scale-100');
            document.body.classList.add('overflow-hidden');
        }

        function closeImageExpand() {
            imageExpandModal.classList.add('opacity-0');
            imageExpandImg.classList.remove('scale-100');
            imageExpandImg.classList.add('scale-95');
            setTimeout(() => {
                imageExpandModal.classList.add('hidden');
                imageExpandImg.src = '';
                document.body.classList.remove('overflow-hidden');
            }, 300);
        }

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && !imageExpandModal.classList.contains('hidden')) {
                closeImageExpand();
            }
        });

        function openIframeModal(url) {
            modalIframe.src = url;
            iframeModal.classList.remove('hidden');
            void iframeModal.offsetWidth;
            iframeModal.classList.remove('opacity-0');
            document.body.classList.add('overflow-hidden');
        }

        function closeIframeModal() {
            iframeModal.classList.add('opacity-0');
            setTimeout(() => {
                iframeModal.classList.add('hidden');
                modalIframe.src = '';
                document.body.classList.remove('overflow-hidden');
            }, 360);
        }

        closeModalBtn.addEventListener('click', closeIframeModal);
        iframeModal.addEventListener('click', (e) => {
            if (e.target === iframeModal) closeIframeModal();
        });

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && !iframeModal.classList.contains('hidden')) {
                closeIframeModal();
            }
        });

        // Greeting Word Carousel
        const wordCarousel = document.getElementById('word-carousel');
        const wordsCount = wordCarousel ? wordCarousel.children.length : 0;
        let currentWordIndex = 0;

        function rotateWords() {
            if (!wordCarousel || wordsCount === 0) return;
            currentWordIndex = (currentWordIndex + 1) % wordsCount;
            const offset = currentWordIndex * -1.2;
            wordCarousel.style.transform = `translateY(${offset}em)`;
        }

        if (!isReducedMotion()) {
            setInterval(rotateWords, 2200);
        }

        // Refined scramble animation for "messy"
        const scrambleWord = document.getElementById('scramble-word');
        const clickWord = document.getElementById('click-word');
        const originalText = 'messy';
        const characters = 'yemss';

        function triggerClickAnimation() {
            if (!clickWord) return;
            clickWord.style.transform = 'scale(1)';
            setTimeout(() => {
                clickWord.style.transform = 'scale(0.965)';
                setTimeout(() => {
                    clickWord.style.transform = 'scale(1.015)';
                    setTimeout(() => {
                        clickWord.style.transform = 'scale(1)';
                    }, 180);
                }, 140);
            }, 620);
        }

        function scramble() {
            if (!scrambleWord) return;
            let iterations = 0;
            const interval = setInterval(() => {
                scrambleWord.innerText = originalText
                    .split('')
                    .map((letter, index) => {
                        if (index < iterations) return originalText[index];
                        return characters[Math.floor(Math.random() * characters.length)];
                    })
                    .join('');

                if (iterations >= originalText.length) {
                    clearInterval(interval);
                    triggerClickAnimation();
                }

                iterations += 1 / 5;
            }, 45);
        }

        if (isReducedMotion()) {
            if (scrambleWord) scrambleWord.innerText = originalText;
            if (clickWord) clickWord.style.transform = 'none';
        } else {
            scramble();
            setInterval(scramble, 4300);
        }

        // Cinematic reveal behavior
        const revealItems = document.querySelectorAll('.reveal-item');

        if (isReducedMotion()) {
            revealItems.forEach((el) => {
                el.classList.add('reveal-init', 'reveal-active');
            });
        } else {
            const observerOptions = {
                threshold: 0.08,
                rootMargin: '0px 0px -8% 0px'
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry, index) => {
                    if (entry.isIntersecting) {
                        const alreadyPlayed = entry.target.dataset.revealed === 'true';
                        const heroDelay = parseInt(entry.target.dataset.delay, 10) || 0;
                        const delay = alreadyPlayed ? 0 : (entry.target.dataset.delay ? heroDelay : index * 120);
                        setTimeout(() => {
                            entry.target.classList.add('reveal-active');
                            entry.target.dataset.revealed = 'true';
                        }, delay);
                    } else {
                        entry.target.classList.remove('reveal-active');
                    }
                });
            }, observerOptions);

            revealItems.forEach((el) => {
                el.classList.add('reveal-init');
                observer.observe(el);
            });
        }

        // Hero parallax system
        const heroSection = document.querySelector('main > section');
        const parallaxLayers = Array.from(document.querySelectorAll('.parallax-layer[data-parallax-depth]'));

        const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

        function setParallaxOffsets(pointerX, pointerY, scrollFactor) {
            parallaxLayers.forEach((layer) => {
                const depth = Number(layer.dataset.parallaxDepth || 0);
                const x = pointerX * depth;
                const y = (pointerY * depth * 0.85) - (scrollFactor * depth * 0.9);
                layer.style.setProperty('--px', `${x.toFixed(2)}px`);
                layer.style.setProperty('--py', `${y.toFixed(2)}px`);
            });
        }

        if (!isReducedMotion() && heroSection && parallaxLayers.length) {
            let targetX = 0;
            let targetY = 0;
            let currentX = 0;
            let currentY = 0;

            heroSection.addEventListener('pointermove', (event) => {
                const rect = heroSection.getBoundingClientRect();
                if (!rect.width || !rect.height) return;
                const nx = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
                const ny = ((event.clientY - rect.top) / rect.height - 0.5) * 2;
                targetX = clamp(nx, -1, 1);
                targetY = clamp(ny, -1, 1);
            });

            heroSection.addEventListener('pointerleave', () => {
                targetX = 0;
                targetY = 0;
            });

            const animateParallax = () => {
                const rect = heroSection.getBoundingClientRect();
                const centerOffset = rect.top + rect.height / 2 - window.innerHeight / 2;
                const scrollFactor = clamp(centerOffset / (window.innerHeight * 0.8), -1.2, 1.2);

                currentX += (targetX - currentX) * 0.08;
                currentY += (targetY - currentY) * 0.08;

                setParallaxOffsets(currentX, currentY, scrollFactor);
                requestAnimationFrame(animateParallax);
            };

            animateParallax();
        } else {
            setParallaxOffsets(0, 0, 0);
        }

        // Selected Works mobile snap carousel
        const workGrid = document.querySelector('.work-grid');
        const workCards = workGrid ? Array.from(workGrid.querySelectorAll('.work-card')) : [];
        const workDotsContainer = document.querySelector('.work-dots');

        if (workGrid && workCards.length && workDotsContainer) {
            // Build dot indicators
            workCards.forEach((_, i) => {
                const dot = document.createElement('button');
                dot.className = 'work-dot';
                dot.type = 'button';
                dot.setAttribute('aria-label', `Go to project ${i + 1}`);
                dot.addEventListener('click', () => {
                    workCards[i].scrollIntoView({
                        behavior: 'smooth',
                        block: 'nearest',
                        inline: 'start'
                    });
                });
                workDotsContainer.appendChild(dot);
            });

            const workDots = Array.from(workDotsContainer.querySelectorAll('.work-dot'));

            const setActiveCard = (idx) => {
                workCards.forEach((c, i) => c.classList.toggle('work-card-active', i === idx));
                workDots.forEach((d, i) => d.classList.toggle('work-dot-active', i === idx));
            };

            // Initial state
            setActiveCard(0);

            const carouselObserver = new IntersectionObserver((entries) => {
                // Pick the entry with the highest intersection ratio
                let best = null;
                entries.forEach((entry) => {
                    if (!best || entry.intersectionRatio > best.intersectionRatio) {
                        best = entry;
                    }
                });
                if (best && best.isIntersecting && best.intersectionRatio >= 0.55) {
                    const idx = workCards.indexOf(best.target);
                    if (idx >= 0) setActiveCard(idx);
                }
            }, {
                root: workGrid,
                threshold: [0.55, 0.7, 0.85]
            });

            workCards.forEach((card) => carouselObserver.observe(card));
        }
    </script>

</body>

</html>