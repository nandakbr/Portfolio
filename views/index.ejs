    <div id="iframe-modal"
        class="fixed inset-0 z-[70] bg-black/90 backdrop-blur-sm hidden opacity-0 transition-opacity duration-300 flex items-center justify-center p-4 cursor-zoom-out">
        <button id="iframe-modal-close"
            class="absolute top-6 right-6 text-white/70 hover:text-white z-10 transition-colors p-2 bg-black/50 rounded-full backdrop-blur-md">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>
        <div class="relative w-full max-w-[85vw] h-[90vh] bg-background-light dark:bg-background-dark rounded-2xl overflow-hidden shadow-2xl"
            onclick="event.stopPropagation()">
            <iframe id="modal-iframe" src="" class="w-full h-full border-0"></iframe>
        </div>
