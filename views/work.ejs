    <div class="fixed inset-0 z-[100] bg-black/90 backdrop-blur-xl opacity-0 pointer-events-none transition-all duration-500 flex items-center justify-center p-4 md:p-12" id="iframeModal">
        <div class="relative w-full max-w-6xl h-full max-h-[85vh] bg-[#050505] rounded-[3rem] overflow-hidden shadow-2xl border border-white/10 scale-95 transition-transform duration-500" id="modalContainer">
            <button class="absolute top-8 right-8 z-[110] bg-white/10 hover:bg-white/20 text-white p-4 rounded-full backdrop-blur-md" onclick="closeIframeModal()">
                <span class="material-symbols-outlined text-2xl">close</span>
            </button>
            <div class="w-full h-full" id="iframeWrapper"></div>
        </div>
    </div>

    <script>
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
        const isReducedMotion = () => prefersReducedMotion.matches;

        const iframeModal = document.getElementById('iframeModal');
        const modalContainer = document.getElementById('modalContainer');
        const iframeWrapper = document.getElementById('iframeWrapper');

        function openIframeModal(url) {
            iframeWrapper.innerHTML = `<iframe src="${url}" class="w-full h-full border-none"></iframe>`;
            iframeModal.classList.remove('opacity-0', 'pointer-events-none');
            modalContainer.classList.remove('scale-95');
            document.body.style.overflow = 'hidden';
        }

        function closeIframeModal() {
            iframeModal.classList.add('opacity-0', 'pointer-events-none');
            modalContainer.classList.add('scale-95');
            setTimeout(() => {
                iframeWrapper.innerHTML = '';
                document.body.style.overflow = '';
            }, 520);
        }

        // Image Expand Logic
        const imageExpandModal = document.getElementById('image-expand-modal');
        const imageExpandImg = document.getElementById('image-expand-img');

        function openImageExpand(src) {
            imageExpandImg.src = src;
            imageExpandModal.classList.remove('hidden');
            void imageExpandModal.offsetWidth;
            imageExpandModal.classList.remove('opacity-0');
            imageExpandImg.classList.remove('scale-95');
            imageExpandImg.classList.add('scale-100');
            document.body.style.overflow = 'hidden';
        }

        function closeImageExpand() {
            imageExpandModal.classList.add('opacity-0');
            imageExpandImg.classList.remove('scale-100');
            imageExpandImg.classList.add('scale-95');
            setTimeout(() => {
                imageExpandModal.classList.add('hidden');
                imageExpandImg.src = '';
                document.body.style.overflow = '';
            }, 300);
        }

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && !imageExpandModal.classList.contains('hidden')) {
                closeImageExpand();
            }
        });

        const revealItems = document.querySelectorAll('.reveal-item');

        if (isReducedMotion()) {
            revealItems.forEach((el) => {
                el.classList.add('reveal-init', 'reveal-active');
            });
        } else {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry, index) => {
                    if (entry.isIntersecting) {
                        const alreadyPlayed = entry.target.dataset.revealed === 'true';
                        const delay = alreadyPlayed ? 0 : index * 110;
                        setTimeout(() => {
                            entry.target.classList.add('reveal-active');
                            entry.target.dataset.revealed = 'true';
                        }, delay);
                    } else {
                        entry.target.classList.remove('reveal-active');
                    }
                });
            }, {
                threshold: 0.08,
                rootMargin: '0px 0px -8% 0px'
            });

            revealItems.forEach((el) => {
                el.classList.add('reveal-init');
                observer.observe(el);
            });
        }

        if (!isReducedMotion()) {
            // Use requestAnimationFrame for tilt to avoid layout thrashing
            document.querySelectorAll('.bento-card-container').forEach((container) => {
                const tiltTarget = container.querySelector('.bento-tilt');
                if (!tiltTarget) return;
                let tiltRAF = null;

                container.addEventListener('pointermove', (event) => {
                    if (tiltRAF) return;
                    tiltRAF = requestAnimationFrame(() => {
                        const rect = container.getBoundingClientRect();
                        if (rect.width && rect.height) {
                            const px = (event.clientX - rect.left) / rect.width;
                            const py = (event.clientY - rect.top) / rect.height;
                            const rotateY = (px - 0.5) * 8;
                            const rotateX = (0.5 - py) * 8;
                            tiltTarget.style.transform = `translateY(-8px) rotateX(${rotateX.toFixed(2)}deg) rotateY(${rotateY.toFixed(2)}deg) scale(1.01)`;
                        }
                        tiltRAF = null;
                    });
                }, { passive: true });

                container.addEventListener('pointerleave', () => {
                    if (tiltRAF) { cancelAnimationFrame(tiltRAF); tiltRAF = null; }
                    tiltTarget.style.transform = '';
                }, { passive: true });
            });
        }
    </script>
