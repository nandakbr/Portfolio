    <style type="text/tailwindcss">
        :root {
            --ease-apple: cubic-bezier(0.22, 1, 0.36, 1);
            --ease-apple-soft: cubic-bezier(0.16, 1, 0.3, 1);
        }

        .reveal-init {
            @apply opacity-0 translate-y-16 scale-[0.97];
            filter: blur(10px);
            transition:
                opacity 1100ms var(--ease-apple),
                transform 1100ms var(--ease-apple),
                filter 900ms var(--ease-apple-soft);
            will-change: transform, opacity, filter;
        }

        .reveal-active {
            @apply opacity-100 translate-y-0 scale-100;
            filter: blur(0);
        }

        section {
            @apply relative z-10;
        }

        body,
        h1,
        h2,
        h3,
        .nav-link {
            font-family: 'Outfit', sans-serif;
        }

        .footer-cta-bg {
            background: linear-gradient(135deg, #050505 0%, #111111 50%, #050505 100%);
            position: relative;
            overflow: hidden;
        }

        .footer-cta-bg::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -20%;
            width: 150%;
            height: 150%;
            background: radial-gradient(circle at center, rgba(255, 255, 255, 0.08) 0%, transparent 70%);
            filter: blur(60px);
            pointer-events: none;
        }

        .bento-card {
            @apply relative overflow-hidden border-none;
            background-color: #F5F5F7;
            transition:
                transform 900ms var(--ease-apple),
                box-shadow 900ms var(--ease-apple),
                background-color 500ms var(--ease-apple-soft);
            box-shadow: 0 1px 0 rgba(255, 255, 255, 0.1) inset;
        }

        .dark .bento-card {
            background-color: #1C1C1E;
        }

        .bento-image-container {
            @apply relative w-full overflow-hidden flex items-center justify-center p-8 lg:p-12;
            transition: transform 1000ms var(--ease-apple);
        }

        .bento-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 30px 70px rgba(0, 0, 0, 0.2);
        }

        .dark .bento-card:hover {
            box-shadow: 0 30px 70px rgba(0, 0, 0, 0.45);
        }

        .bento-card:hover .bento-image-container {
            @apply scale-[1.04];
        }

        .bento-card-container {
            perspective: 2200px;
        }

        .bento-tilt {
            transition: transform 900ms var(--ease-apple-soft);
            transform-style: preserve-3d;
            will-change: transform;
        }

        .bento-card-container:hover .bento-tilt {
            transform: translateY(-5px) rotateX(1.4deg) rotateY(-1.4deg);
        }

        @media (prefers-reduced-motion: reduce) {
            *,
            *::before,
            *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
                scroll-behavior: auto !important;
            }

            .reveal-init {
                opacity: 1 !important;
                transform: none !important;
                filter: none !important;
            }

            .bento-tilt,
            .bento-card,
            .bento-image-container {
                transform: none !important;
            }
        }
    </style>
</head>

