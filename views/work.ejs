    <!-- Image Expand Modal -->
    <div id="image-expand-modal"
        class="fixed inset-0 z-[110] bg-black/90 backdrop-blur-sm hidden opacity-0 transition-opacity duration-300 flex items-center justify-center p-4 cursor-zoom-out"
        onclick="closeImageExpand()">
        <button
            class="absolute top-6 right-6 text-white/70 hover:text-white z-10 transition-colors p-2 bg-black/50 rounded-full backdrop-blur-md"
            onclick="event.stopPropagation(); closeImageExpand()">
