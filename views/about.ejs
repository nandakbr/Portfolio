<!DOCTYPE html>
<html class="scroll-smooth dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>
        <%= title %>
    </title>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link
        href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&amp;display=swap"
        rel="stylesheet" />
    <link
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap"
        rel="stylesheet" media="print" onload="this.media='all'" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography,container-queries"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#000000",
                        "primary-secondary": "#666666",
                        "background-light": "#F9F9F9",
                        "background-dark": "#050505",
                        "background-elevated": "#111111",
                        "cta-default": "#000000",
                        "cta-hover": "#333333",
                        "btn-default": "#000000",
                        "btn-hover": "#333333",
                        "border-color": "#E5E5E5",
                    },
                    fontFamily: {
                        display: ["Outfit", "sans-serif"],
                        body: ["Outfit", "sans-serif"],
                    },
                    borderRadius: {
                        DEFAULT: "0.5rem",
                        '4xl': '2rem',
                    },
                },
            },
        };
    </script>
    <style type="text/tailwindcss">
        :root {
            --ease-apple: cubic-bezier(0.22, 1, 0.36, 1);
            --ease-apple-soft: cubic-bezier(0.16, 1, 0.3, 1);
        }

        .reveal-init {
            @apply opacity-0 translate-y-16 scale-[0.97];
            filter: blur(10px);
            transition:
                opacity 1100ms var(--ease-apple),
                transform 1100ms var(--ease-apple),
                filter 900ms var(--ease-apple-soft);
            will-change: transform, opacity, filter;
        }

        .reveal-active {
            @apply opacity-100 translate-y-0 scale-100;
            filter: blur(0);
        }

        section {
            @apply relative z-10;
        }

        body,
        h1,
        h2,
        h3,
        .nav-link {
            font-family: 'Outfit', sans-serif;
        }

        .footer-cta-bg {
            background: linear-gradient(135deg, #050505 0%, #111111 50%, #050505 100%);
            position: relative;
            overflow: hidden;
        }

        .footer-cta-bg::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -20%;
            width: 150%;
            height: 150%;
            background: radial-gradient(circle at center, rgba(255, 255, 255, 0.08) 0%, transparent 70%);
            filter: blur(60px);
            pointer-events: none;
        }

        .footer-cta-bg::after {
            content: '';
            position: absolute;
            top: 20%;
            right: -10%;
            width: 80%;
            height: 60%;
            background: radial-gradient(ellipse at center, rgba(255, 255, 255, 0.05) 0%, transparent 80%);
            transform: rotate(-15deg);
            filter: blur(40px);
            pointer-events: none;
        }

        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }

        .pill {
            @apply bg-black dark:bg-white text-white dark:text-black px-6 py-2 rounded-full text-sm font-medium;
            transition: transform 700ms var(--ease-apple-soft), box-shadow 700ms var(--ease-apple-soft);
        }

        .pill:hover {
            transform: translateY(-2px) scale(1.03);
            box-shadow: 0 12px 28px rgba(0, 0, 0, 0.14);
        }

        .work-row {
            @apply flex flex-col md:flex-row justify-between items-start md:items-center py-6 border-b border-[#E5E5E5] dark:border-[#262626];
            transition: transform 650ms var(--ease-apple-soft), background-color 650ms var(--ease-apple-soft);
        }

        .work-row:hover {
            transform: translateX(8px);
        }

        .work-row-active {
            @apply bg-black dark:bg-white text-white dark:text-black px-8 rounded-2xl shadow-xl;
        }

        .philosophy-card {
            @apply relative overflow-hidden rounded-[2.5rem] p-10 cursor-default;
            background-color: #F5F5F7;
            transition:
                transform 850ms var(--ease-apple),
                box-shadow 850ms var(--ease-apple),
                background-color 500ms var(--ease-apple-soft);
            box-shadow: 0 1px 0 rgba(255, 255, 255, 0.1) inset;
        }

        .philosophy-card::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(120deg, transparent 20%, rgba(255, 255, 255, 0.3) 48%, transparent 70%);
            transform: translateX(-120%);
            transition: transform 1100ms var(--ease-apple-soft);
            pointer-events: none;
        }

        .philosophy-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 26px 60px rgba(0, 0, 0, 0.14);
        }

        .philosophy-card:hover::after {
            transform: translateX(120%);
        }

        .dark .philosophy-card {
            background-color: #1C1C1E;
        }

        .dark .philosophy-card:hover {
            box-shadow: 0 26px 60px rgba(0, 0, 0, 0.4);
        }

        .philosophy-number {
            @apply text-[6rem] font-black leading-none opacity-[0.04] absolute -top-4 -left-2 select-none pointer-events-none;
        }

        @media (prefers-reduced-motion: reduce) {
            *,
            *::before,
            *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
                scroll-behavior: auto !important;
            }

            .reveal-init {
                opacity: 1 !important;
                transform: none !important;
                filter: none !important;
            }

            .philosophy-card,
            .pill,
            .work-row {
                transform: none !important;
            }
        }
    </style>
</head>

